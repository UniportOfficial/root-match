# Rootmatching API — 환경변수 예시
# 실제 값을 채워서 apps/api/.env로 복사하세요.

# ── Phase 1.Week 1 (현재) ──

# OpenAI API (AI 매칭 모듈에서 사용)
# Reference: https://platform.openai.com/api-keys
# - 설정 시: text-embedding-3-small + GPT-4o 실제 호출
# - 미설정 + dev/test: deterministic mock 추천 자동 반환 (AIM-004 정책)
# - 미설정 + production: 500 throw (MATCHING_MOCK_FALLBACK=true 명시 opt-in 필요)
OPENAI_API_KEY=sk-...

# AI 매칭 mock fallback opt-in (production 전용)
# - dev/test: 별도 설정 없이도 OPENAI_API_KEY 없으면 자동 mock 반환
# - production: 반드시 OPENAI_API_KEY를 채우는 것이 기본. 의도적으로 mock을 쓰려면 "true"로 설정
# Reference: docs/specs/rootmatching-backend-checklist.md AIM-004
# MATCHING_MOCK_FALLBACK=

# 서버 포트 (기본: 3000, web과 충돌 시 3001 권장)
PORT=3001

# Web origin (CORS 허용 origin, 기본: http://localhost:3000)
# WEB_ORIGIN=http://localhost:3000

# ── Phase 1.Week 2 (Pre-Flight applied 2026-06-03) ──

# Neon PostgreSQL — POOLED connection string (runtime)
# Reference: https://console.neon.tech
# 형식: postgresql://USER:PASS@ep-XXX-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connect_timeout=15
# DATABASE_URL=

# Neon PostgreSQL — DIRECT connection string (migrations only, no pgbouncer)
# 형식: postgresql://USER:PASS@ep-XXX.REGION.aws.neon.tech/DB?sslmode=require
# DIRECT_URL=

# Better Auth (자체 호스팅; Better Auth 1.6+)
# openssl rand -base64 32 로 생성
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3001

# Cookie 서명 (cookie-parser, Better Auth signed cookies)
# openssl rand -base64 32 로 생성
# COOKIE_SECRET=

# Logging level (nestjs-pino) — debug / info / warn / error
# LOG_LEVEL=info

# ── Phase 3 (Contracts vendor integration) ──
# Reference: docs/specs/ucansign-api-reference.md §1.2

# Contract gateway selector. mock = in-memory, no vendor call (default for safety).
# Switch to "ucansign" when template + webhook secret are provisioned.
# CONTRACT_GATEWAY=mock

# Vendor API key (개발자센터에서 발급, https://app.ucansign.com/developer)
# 90일 주기 rotate 권장. NEVER commit actual value.
# UCANSIGN_API_KEY=

# Vendor API base URL (변경 가능성 낮음, default OK)
# UCANSIGN_BASE_URL=https://app.ucansign.com/openapi

# Test mode: vendor 호출 시 x-ucansign-test:true 헤더 자동 추가
# - true: 포인트 차감 0, 워터마크 PDF, 법적 효력 없음 — dev/staging 권장
# - false 또는 미설정: 실 발송 (1건당 100원 차감)
# UCANSIGN_TEST_MODE=true

# 서명 기본 만료기간 (분). vendor default = 14일 (20160분)
# UCANSIGN_DEFAULT_EXPIRY_MINUTES=20160

# Webhook HMAC signing secret (vendor 발급 시 채움)
# Policy:
#   - secret 설정 → HMAC-SHA256(raw body bytes) strict 검증
#   - secret 미설정 + NODE_ENV=production → 401 reject (fail-safe)
#   - secret 미설정 + dev/test → 검증 skip, customValue5 매칭 fallback (§8.3)
# UCANSIGN_WEBHOOK_SECRET=
# UCANSIGN_WEBHOOK_SIGNATURE_HEADER=x-ucansign-signature

# ── Phase 4 (Production readiness checklist) ──
# Required before NODE_ENV=production:
#
# 1. DATABASE_URL — Neon pooled connection string set
# 2. BETTER_AUTH_SECRET — ≥32 chars (openssl rand -base64 32)
# 3. BETTER_AUTH_URL — public API origin (e.g. https://api.rootmatching.com)
# 4. COOKIE_SECRET — ≥32 chars
# 5. UCANSIGN_API_KEY — vendor developer center
# 6. UCANSIGN_WEBHOOK_SECRET — vendor HMAC secret
# 7. OPENAI_API_KEY — actual API key (or MATCHING_MOCK_FALLBACK=true for opt-in mock)
# 8. UCANSIGN_TEST_MODE=false — real document dispatch
# 9. CONTRACT_GATEWAY=ucansign — real vendor adapter
#
# External setup before flip:
#   a. UCanSign console: register 26 PDF placeholder fields under the template
#   b. UCanSign console: register webhook URL (https://<host>/webhooks/ucansign)
#   c. UCanSign console: request webhook HMAC secret
#   d. Fixed webhook URL: named Cloudflared tunnel or production API host
#
# On NODE_ENV=production boot, env-validator.ts runs and exits 1 if any required
# variable is missing. dev/test/staging skip validation entirely.
