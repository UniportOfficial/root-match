# Rootmatching API — 환경변수 예시
# 실제 값을 채워서 apps/api/.env로 복사하세요.

# ── Phase 1.Week 1 (현재) ──

# OpenAI API (AI 매칭 모듈에서 사용)
# Reference: https://platform.openai.com/api-keys
# - 설정 시: text-embedding-3-small + GPT-4o 실제 호출
# - 미설정 + dev/test: deterministic mock 추천 자동 반환 (AIM-004 정책)
# - 미설정 + production: 500 throw (MATCHING_MOCK_FALLBACK=true 명시 opt-in 필요)
OPENAI_API_KEY=sk-...

# AI 매칭 mock fallback opt-in (production 전용)
# - dev/test: 별도 설정 없이도 OPENAI_API_KEY 없으면 자동 mock 반환
# - production: 반드시 OPENAI_API_KEY를 채우는 것이 기본. 의도적으로 mock을 쓰려면 "true"로 설정
# Reference: docs/specs/rootmatching-backend-checklist.md AIM-004
# MATCHING_MOCK_FALLBACK=

# 서버 포트 (기본: 3000, web과 충돌 시 3001 권장)
PORT=3001

# Web origin (CORS 허용 origin, 기본: http://localhost:3000)
# WEB_ORIGIN=http://localhost:3000

# ── Phase 1.Week 2 (Pre-Flight applied 2026-06-03) ──

# Neon PostgreSQL — POOLED connection string (runtime)
# Reference: https://console.neon.tech
# 형식: postgresql://USER:PASS@ep-XXX-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connect_timeout=15
# DATABASE_URL=

# Neon PostgreSQL — DIRECT connection string (migrations only, no pgbouncer)
# 형식: postgresql://USER:PASS@ep-XXX.REGION.aws.neon.tech/DB?sslmode=require
# DIRECT_URL=

# Better Auth (자체 호스팅; Better Auth 1.6+)
# openssl rand -base64 32 로 생성
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3001

# Cookie 서명 (cookie-parser, Better Auth signed cookies)
# openssl rand -base64 32 로 생성
# COOKIE_SECRET=

# Logging level (nestjs-pino) — debug / info / warn / error
# LOG_LEVEL=info
