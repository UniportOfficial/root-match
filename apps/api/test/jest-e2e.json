{
  "moduleFileExtensions": ["js", "json", "ts", "mjs"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "globalSetup": "<rootDir>/jest-e2e.globalSetup.ts",
  "transform": {
    "^.+\\.(t|j|mj)s$": [
      "ts-jest",
      {
        "isolatedModules": true,
        "diagnostics": false
      }
    ]
  },
  "transformIgnorePatterns": [
    "node_modules/(?!.*(better-auth|@better-auth|better-call|@better-fetch|@noble|nanostores|jose|uncrypto|defu|destr|kysely|@simplewebauthn|rou3))"
  ]
}
