# Rootmatching API — 환경변수 예시
# 실제 값을 채워서 apps/api/.env로 복사하세요.

# ── Phase 1.Week 1 (현재) ──

# OpenAI API (AI 매칭 모듈에서 사용)
# Reference: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# 서버 포트 (기본: 3000, web과 충돌 시 3001 권장)
PORT=3001

# ── Phase 1.Week 2 (예정) ──

# Neon PostgreSQL connection string (Prisma 도입 시)
# Reference: https://console.neon.tech
# DATABASE_URL=postgresql://user:pass@ep-xxx.aws.neon.tech/rootmatching?sslmode=require

# Better Auth (자체 호스팅)
# openssl rand -base64 32 로 생성
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3001
