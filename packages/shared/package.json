{
  "name": "@rootmatching/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Rootmatching 공용 zod schemas, 도메인 타입, 상수 (web/api 공유)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "default": "./dist/constants/index.js"
    },
    "./fixtures/factory-data": {
      "types": "./dist/fixtures/factory-data.d.ts",
      "default": "./dist/fixtures/factory-data.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "zod": "^4.4.3",
    "typescript": "^5.7.3"
  }
}
